# PDF Oluşturma API Ayarları
# html2pdf.app API key'inizi buraya ekleyin
PDF_API_KEY=api keyiniz

# Resend API (e-posta gönderimi) - https://resend.com
RESEND_API_KEY=re_xxxxxxxxxxxx

# E-posta Adresleri (Resend'de gönderici domain doğrulaması gerekebilir)
EMAIL_FROM=gönderen@domain.com
EMAIL_TO=alıcı@email.com

# Aylık rapor otomatik gönderim (uygulama içi)
# 1, true veya yes ise: her ayın 1'i 09:00 (İstanbul) bir önceki ayın raporu EMAIL_TO'ya gönderilir
# AYLIK_RAPOR_OTOMATIK=1

# Aylık rapor cron güvenliği (opsiyonel, sadece dış cron kullanıyorsanız)
# POST /api/aylik-rapor/gonder çağrısında secret veya X-Cron-Secret ile eşleşmeli
# CRON_SECRET=
